---
import Base from '../layouts/Base.astro';

const projects = [
	{
		num: 'P01',
		title: 'Slow & Fast',
		subtitle: '卡牌圈地桌游',
		year: '2024',
		context: 'UAL · 独立完成',
		blurb: '3×4 网格上用牌画线圈地的多人对抗桌游。围绕"随机性如何影响竞争性与策略性"展开的设计探索。',
		tag: 'TABLETOP',
	},
	{
		num: 'P03',
		title: 'Ash of Aetharn',
		subtitle: '肉鸽 · 即时战略 · 卡牌',
		year: '进行中',
		context: '独立开发',
		blurb: '探索"探索系统作为肉鸽创新维度"的可能性——天气系统、RTS 式自由地图、刻印诅咒事件。',
		tag: 'IN PROGRESS',
	},
];
---

<Base title="纸城 — Works" current="Works" pageNum="02">
	<section class="hero hero--small">
		<div class="bg-diagonal bg-diagonal--small"></div>
		<div class="hero__inner">
			<div class="eyebrow fade-up fade-up--1">02 ─ WORKS</div>
			<h1 class="display-lg fade-up fade-up--2">Works</h1>
			<p class="lead fade-up fade-up--3" style="margin-top: var(--s-5); max-width: 540px">
				我做过的游戏项目<br />与对他人作品的设计分析。
			</p>
		</div>
	</section>

	<section class="section">
		<div class="section__head">
			<span class="eyebrow">01 / Projects</span>
			<h2>Projects</h2>
		</div>
		<div class="works-grid">
			{projects.map((p, i) => (
				<a href="#" class={`work-card ${i % 2 === 0 ? 'work-card--tilt-l' : 'work-card--tilt-r'}`}>
					<div class="work-card__overlay"></div>
					<div class="work-card__head">
						<span class="work-card__num">{p.num}</span>
						<span class="work-card__tag">{p.tag}</span>
					</div>
					<div class="work-card__main">
						<h3 class="work-card__title">{p.title}</h3>
						<div class="work-card__sub">{p.subtitle}</div>
					</div>
					<div class="work-card__foot">
						<p class="work-card__blurb">{p.blurb}</p>
						<div class="work-card__meta">
							<span>{p.context}</span>
							<span>{p.year}</span>
						</div>
					</div>
					<div class="work-card__arrow">→</div>
				</a>
			))}
		</div>
	</section>

	<section class="section">
		<div class="section__head">
			<span class="eyebrow">02 / Game Analysis</span>
			<h2>Game Analysis</h2>
		</div>
		<div class="empty-state">
			<div class="empty-state__num">.0</div>
			<p>[占位 — 等你做完第一篇游戏分析后填充]</p>
		</div>
	</section>
</Base>

<style>
	.hero--small { min-height: 40vh; padding-bottom: var(--s-7); }

	.works-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--s-6);
	}
	.work-card {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: var(--s-6);
		padding: var(--s-6) var(--s-7);
		background: var(--bg-soft);
		border: 1px solid var(--line);
		transition: all var(--duration) var(--ease-out);
		overflow: hidden;
	}
	.work-card--tilt-l:hover { transform: translateX(-6px); }
	.work-card--tilt-r:hover { transform: translateX(6px); }
	.work-card:hover { border-color: var(--accent); }
	.work-card__overlay {
		position: absolute;
		inset: 0;
		background: var(--accent);
		transform: translateX(-100%);
		transition: transform var(--duration) var(--ease-out);
		z-index: 0;
	}
	.work-card:hover .work-card__overlay { transform: translateX(0); }
	.work-card > *:not(.work-card__overlay) { position: relative; z-index: 1; }

	.work-card__head {
		display: flex;
		flex-direction: column;
		gap: var(--s-2);
		padding-right: var(--s-5);
		border-right: 1px solid var(--line);
		min-width: 100px;
	}
	.work-card__num {
		font-family: var(--font-display);
		font-size: 32px;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--accent-bright);
		transition: color var(--duration) var(--ease);
	}
	.work-card:hover .work-card__num { color: var(--ink); }
	.work-card__tag {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.2em;
		color: var(--ink-muted);
	}

	.work-card__main { padding-right: var(--s-4); }
	.work-card__title {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 32px;
		line-height: 1;
		font-weight: 500;
	}
	.work-card__sub {
		margin-top: var(--s-2);
		color: var(--ink-secondary);
		font-style: italic;
	}
	.work-card__blurb {
		margin-top: var(--s-3);
		color: var(--ink-secondary);
		font-size: 15px;
	}
	.work-card__meta {
		margin-top: var(--s-3);
		display: flex;
		gap: var(--s-4);
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-muted);
	}
	.work-card__arrow {
		align-self: center;
		font-size: 24px;
		color: var(--ink-muted);
		transition: all var(--duration) var(--ease);
	}
	.work-card:hover .work-card__arrow {
		color: var(--ink);
		transform: translateX(4px);
	}

	.empty-state {
		padding: var(--s-7);
		border: 1px dashed var(--line);
		display: flex;
		gap: var(--s-5);
		align-items: center;
	}
	.empty-state__num {
		font-family: var(--font-display);
		font-size: 64px;
		color: var(--ink-faint);
		line-height: 1;
	}
	.empty-state p { color: var(--ink-muted); font-style: italic; }

	@media (max-width: 700px) {
		.work-card { grid-template-columns: 1fr; }
		.work-card__head {
			flex-direction: row;
			padding-right: 0;
			border-right: none;
			border-bottom: 1px solid var(--line);
			padding-bottom: var(--s-3);
			align-items: baseline;
		}
		.work-card__arrow { display: none; }
	}
</style>
