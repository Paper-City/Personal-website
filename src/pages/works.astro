---
import Base from '../layouts/Base.astro';

// Project tiles for the album.
// Each tile occupies a grid area defined in CSS via the `area` field.
// `cover` is a public image path; if absent, render a solid color block.
const projects = [
	{
		num: 'P03',
		title: 'Ash of Aetharn',
		subtitle: '肉鸽 · RTS · 卡牌',
		year: '进行中',
		cover: '/prototype.jpg',
		area: 'ash',
		href: '#',
	},
	{
		num: 'P02',
		title: 'Outside the Blue',
		subtitle: '太空生存 · 群组项目',
		year: 'UAL · 2025',
		cover: '/cover-outside-the-blue.png',
		area: 'otb',
		href: '#',
	},
	{
		num: 'P01',
		title: 'Slow & Fast',
		subtitle: '卡牌圈地桌游',
		year: 'UAL · 2024',
		cover: null,
		fill: 'oxblood',
		area: 'sf',
		href: '#',
	},
];

const placeholders = [
	{ area: 'p1', fill: 'blue-deep', label: 'Coming Soon' },
	{ area: 'p2', fill: 'blue-bright', label: 'Coming Soon' },
];
---

<Base title="纸城 — 作品" current="作品">
	<section class="works-hero">
		<div class="works-hero__inner">
			<div class="eyebrow fade-up fade-up--1">02 ─ 作品</div>
			<h1 class="display-lg fade-up fade-up--2">Works</h1>
			<p class="lead fade-up fade-up--3">
				我做过的游戏项目与原型。
			</p>
		</div>
	</section>

	<section class="album fade-up fade-up--4">
		{projects.map((p) => (
			<a href={p.href} class={`album__tile area-${p.area} ${p.cover ? '' : 'album__tile--solid'} ${p.fill ? `fill-${p.fill}` : ''}`}>
				{p.cover && <img src={p.cover} alt={p.title} loading="lazy" />}
				<div class="album__overlay">
					<div class="album__num">{p.num}</div>
					<div class="album__title">{p.title}</div>
					<div class="album__sub">{p.subtitle}</div>
					<div class="album__year">{p.year}</div>
				</div>
			</a>
		))}

		{placeholders.map((p) => (
			<div class={`album__tile album__tile--coming area-${p.area} fill-${p.fill}`}>
				<div class="album__overlay">
					<div class="album__num">—</div>
					<div class="album__title album__title--coming">{p.label}</div>
				</div>
			</div>
		))}
	</section>
</Base>

<style>
	.works-hero {
		padding-top: var(--s-7);
		padding-bottom: var(--s-7);
	}
	.works-hero__inner {
		max-width: 720px;
	}
	.works-hero .lead {
		margin-top: var(--s-4);
		max-width: 540px;
	}

	/* ---------- Album Grid ---------- */
	.album {
		display: grid;
		grid-template-columns: 2fr 1.2fr 1.2fr;
		grid-template-rows: 320px 200px 240px;
		grid-template-areas:
			"ash  otb  sf"
			"ash  otb  p1"
			"p2   p2   p1";
		gap: 12px;
		margin-top: var(--s-7);
	}

	.area-ash { grid-area: ash; }
	.area-otb { grid-area: otb; }
	.area-sf  { grid-area: sf; }
	.area-p1  { grid-area: p1; }
	.area-p2  { grid-area: p2; }

	/* ---------- Tile ---------- */
	.album__tile {
		position: relative;
		overflow: hidden;
		border: 1px solid var(--line);
		background: var(--bg-soft);
		display: block;
		text-decoration: none;
		color: var(--ink);
		transition: transform var(--duration) var(--ease), border-color var(--duration) var(--ease);
		cursor: pointer;
	}
	.album__tile:hover {
		border-color: var(--accent-bright);
		transform: translateY(-4px);
	}
	.album__tile--coming { cursor: default; }
	.album__tile--coming:hover { transform: none; border-color: var(--line); }

	/* Solid color fills (when no cover image) */
	.fill-oxblood { background: linear-gradient(135deg, #7E2A24 0%, #4A1815 100%); }
	.fill-blue-deep { background: linear-gradient(135deg, #0F1E80 0%, #060B40 100%); }
	.fill-blue-bright { background: linear-gradient(135deg, #1E40FF 0%, #0F1E80 100%); }

	/* Cover image */
	.album__tile img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 600ms var(--ease-out), filter var(--duration) var(--ease);
		filter: saturate(0.85) contrast(1.05);
	}
	.album__tile:hover img {
		transform: scale(1.05);
		filter: saturate(1.1) contrast(1.1);
	}

	/* Dark gradient overlay for legibility */
	.album__tile::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0) 100%);
		z-index: 1;
		pointer-events: none;
	}
	.album__tile--coming::before {
		background: linear-gradient(to top, rgba(0,0,0,0.4), rgba(0,0,0,0.1));
	}

	/* Overlay text content */
	.album__overlay {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		padding: var(--s-5) var(--s-5) var(--s-4);
		z-index: 2;
		color: var(--ink);
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.album__num {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.22em;
		color: var(--accent-bright);
		margin-bottom: var(--s-2);
	}
	.album__title {
		font-family: var(--font-display);
		font-size: clamp(20px, 2.4vw, 30px);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.01em;
	}
	.album__title--coming {
		font-weight: 500;
		color: var(--ink-muted);
		font-size: 18px;
	}
	.album__sub {
		margin-top: var(--s-2);
		font-size: 13px;
		color: var(--ink-secondary);
	}
	.album__year {
		margin-top: var(--s-2);
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.2em;
		color: var(--ink-muted);
		text-transform: uppercase;
	}

	/* Shrink overlay text on smaller tiles (sf, p1) */
	.area-sf .album__title,
	.area-p1 .album__title {
		font-size: clamp(18px, 1.8vw, 22px);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.album {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: 280px 200px 200px 180px;
			grid-template-areas:
				"ash ash"
				"otb sf"
				"otb p1"
				"p2  p2";
		}
	}
	@media (max-width: 600px) {
		.album {
			grid-template-columns: 1fr;
			grid-template-rows: repeat(5, 200px);
			grid-template-areas:
				"ash"
				"otb"
				"sf"
				"p1"
				"p2";
			gap: 8px;
		}
	}
</style>
