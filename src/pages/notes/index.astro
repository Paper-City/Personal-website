---
import Base from '../../layouts/Base.astro';

const notes = [
	{
		date: '2025.10',
		tag: 'philosophy',
		title: '我的游戏设计世界观',
		length: '~10 min',
		href: '/notes/balance',
	},
];
---

<Base title="纸城 — 笔记" current="笔记">
	<section class="hero hero--small">
		<div class="bg-diagonal bg-diagonal--small"></div>
		<div class="hero__inner">
			<div class="eyebrow fade-up fade-up--1">03 ─ 笔记</div>
			<h1 class="display-lg fade-up fade-up--2">Notes</h1>
			<p class="lead fade-up fade-up--3" style="margin-top: var(--s-5); max-width: 540px">
				关于设计、AI 与游戏行业的<br />零碎思考。
			</p>
		</div>
	</section>

	<section class="section">
		<ul class="notes">
			{notes.map((n, i) => (
				<li class="note">
					<a href={n.href} class="note__link">
						<div class="note__num">.{String(i + 1).padStart(2, '0')}</div>
						<div class="note__meta">
							<span class="note__date">{n.date}</span>
							<span class="note__tag">{n.tag}</span>
						</div>
						<h3 class="note__title">{n.title}</h3>
						<div class="note__length">{n.length}</div>
						<div class="note__arrow">→</div>
					</a>
				</li>
			))}
		</ul>
	</section>
</Base>

<style>
	.hero--small { min-height: 40vh; padding-bottom: var(--s-7); }

	.notes { list-style: none; }
	.note {
		position: relative;
		border-bottom: 1px solid var(--line);
	}
	.note__link {
		position: relative;
		display: grid;
		grid-template-columns: 60px 140px 1fr 80px 30px;
		gap: var(--s-5);
		padding: var(--s-5) var(--s-4);
		align-items: baseline;
		transition: all var(--duration) var(--ease);
		color: inherit;
		text-decoration: none;
	}
	.note__link::before {
		content: '';
		position: absolute;
		inset: 0;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--duration) var(--ease-out);
		z-index: 0;
	}
	.note__link:hover::before { transform: scaleX(1); }
	.note__link > * { position: relative; z-index: 1; transition: color var(--duration) var(--ease); }
	.note__link:hover { padding-left: var(--s-6); }

	.note__num {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--ink-faint);
	}
	.note__meta {
		display: flex;
		flex-direction: column;
		gap: var(--s-1);
	}
	.note__date {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.12em;
		color: var(--accent-bright);
	}
	.note__link:hover .note__date { color: var(--ink); }
	.note__tag {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.22em;
		color: var(--ink-muted);
		text-transform: uppercase;
	}
	.note__title {
		font-family: var(--font-display);
		font-size: 22px;
		font-weight: 500;
		color: var(--ink);
	}
	.note__length {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.15em;
		color: var(--ink-muted);
		text-transform: uppercase;
	}
	.note__arrow {
		font-size: 18px;
		color: var(--ink-muted);
		transition: transform var(--duration) var(--ease);
	}
	.note__link:hover .note__arrow {
		color: var(--ink);
		transform: translateX(4px);
	}
	.note__link:hover .note__num { color: rgba(255,255,255,0.6); }
	.note__link:hover .note__tag { color: rgba(255,255,255,0.7); }
	.note__link:hover .note__length { color: rgba(255,255,255,0.7); }

	@media (max-width: 800px) {
		.note__link { grid-template-columns: 60px 1fr 30px; }
		.note__meta { grid-row: 2; grid-column: 1 / -1; }
		.note__title { grid-column: 2; }
		.note__length { display: none; }
	}
</style>
