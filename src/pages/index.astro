---
import Base from '../layouts/Base.astro';
---

<Base title="纸城 — About Me" current="About Me" pageNum="01">
	<!-- HERO: dramatic Persona-style opening -->
	<section class="hero">
		<div class="bg-diagonal"></div>

		<div class="tile-collage" aria-hidden="true">
			<div class="tile tile--workshop" data-rotate="5" data-depth="3">
				<img src="/workshop.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--exhibition" data-rotate="-7" data-depth="3">
				<img src="/exhibition.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--presentation" data-rotate="-5" data-depth="2">
				<img src="/presentation.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--prototype" data-rotate="3" data-depth="2">
				<img src="/prototype.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--portrait" data-rotate="-4" data-depth="1">
				<img src="/avatar.png" alt="" />
			</div>
			<div class="tile tile--accent" data-rotate="14" data-depth="1"></div>
		</div>

		<div class="hero__inner">
			<div class="eyebrow hero__eyebrow fade-up fade-up--1">01 ─ ABOUT ME</div>

			<div class="hero__head fade-up fade-up--2">
				<div class="hero__name">
					<h1 class="display-xl hero__cn">纸城</h1>
					<div class="hero__en">PAPER CITY</div>
					<div class="hero__author">HUANG TINGYU</div>
				</div>

				<div class="hero__schools">
					<div class="school">
						<span class="school__name">哈尔滨工业大学</span>
						<span class="school__field">软件工程（数字媒体技术）</span>
					</div>
					<div class="school">
						<span class="school__name">伦敦艺术大学</span>
						<span class="school__field">游戏设计</span>
					</div>
				</div>
			</div>

			<p class="hero__lead fade-up fade-up--4">
				我是一名关注<strong>玩法系统</strong>、<strong>交互体验</strong>与<strong>原型实现</strong>的游戏设计师与开发者。
			</p>
		</div>

		<div class="scroll-hint">
			<span>Scroll</span>
			<svg width="14" height="20" viewBox="0 0 14 20" fill="none">
				<path d="M7 1V19M7 19L1 13M7 19L13 13" stroke="currentColor" stroke-width="1"/>
			</svg>
		</div>
	</section>

	<!-- BODY -->
	<section class="section">
		<div class="section__head">
			<span class="eyebrow">02 / Philosophy</span>
			<h2>我的设计理念</h2>
		</div>
		<p class="philosophy">
			我相信游戏不仅是艺术的表达，更是严谨的工程。
		</p>
		<p class="philosophy">
			比起追求灵光一现，我更喜欢通过理论与测试将设计逐步打磨成有趣的玩法。
		</p>
	</section>

	<section class="section">
		<div class="section__head">
			<span class="eyebrow">03 / Research</span>
			<h2>我在研究的</h2>
		</div>
		<ul class="research-list">
			<li><span class="research-num">.01</span>随机性在提高游戏复玩性中的应用</li>
			<li><span class="research-num">.02</span>提高交互性的隐性系统设计</li>
			<li><span class="research-num">.03</span>AI 与游戏结合</li>
		</ul>
	</section>
</Base>

<style>
	.hero { min-height: 80vh; }
	.hero__inner {
		max-width: 760px;
		position: relative;
		z-index: 2;
	}

	/* Name + schools row */
	.hero__head {
		display: flex;
		align-items: flex-end;
		gap: var(--s-7);
		flex-wrap: wrap;
		margin-top: var(--s-4);
	}

	/* Name block */
	.hero__name {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.hero__cn {
		color: var(--ink);
		font-weight: 600;
	}
	.hero__en {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 500;
		font-size: clamp(28px, 4vw, 44px);
		color: var(--ink);
		line-height: 1;
		letter-spacing: 0.02em;
	}
	.hero__author {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.32em;
		color: var(--ink);
		text-transform: uppercase;
		margin-top: var(--s-3);
	}

	/* Schools — to the right of name, two rows, dark blue */
	.hero__schools {
		display: flex;
		flex-direction: column;
		gap: var(--s-3);
		padding-bottom: var(--s-2);
		--school-blue: #5A7BCC;
	}
	.school {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.school__name {
		font-family: var(--font-display);
		font-size: 18px;
		font-weight: 500;
		color: var(--school-blue);
		letter-spacing: 0.01em;
	}
	.school__field {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		color: var(--school-blue);
		opacity: 0.75;
		text-transform: uppercase;
	}

	/* Lead paragraph */
	.hero__lead {
		margin-top: var(--s-7);
		font-family: var(--font-display);
		font-size: clamp(20px, 2.4vw, 28px);
		line-height: 1.5;
		color: var(--ink);
		max-width: 640px;
		font-style: italic;
	}
	.hero__lead strong {
		color: var(--accent-bright);
		font-weight: 600;
		font-style: normal;
		font-family: var(--font-display);
	}

	.scroll-hint {
		position: absolute;
		bottom: var(--s-6);
		left: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--s-2);
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		color: var(--ink-muted);
		z-index: 2;
		animation: bobble 2.4s ease-in-out infinite;
	}
	@keyframes bobble {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(8px); }
	}

	/* Philosophy */
	.philosophy {
		font-family: var(--font-display);
		font-size: clamp(20px, 2.2vw, 26px);
		line-height: 1.55;
		color: var(--ink);
		max-width: 700px;
	}
	.philosophy + .philosophy {
		margin-top: var(--s-4);
		color: var(--ink-secondary);
		font-style: italic;
	}

	/* Research list */
	.research-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--s-3);
	}
	.research-list li {
		display: flex;
		align-items: baseline;
		gap: var(--s-5);
		padding: var(--s-3) 0;
		border-bottom: 1px solid var(--line);
		font-family: var(--font-display);
		font-size: clamp(20px, 2vw, 24px);
		color: var(--ink);
		transition: color var(--duration) var(--ease);
	}
	.research-list li:hover { color: var(--accent-bright); }
	.research-num {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.2em;
		color: var(--accent-bright);
		min-width: 50px;
	}

	@media (max-width: 900px) {
		.hero__head { flex-direction: column; align-items: flex-start; gap: var(--s-5); }
		.hero__schools { padding-bottom: 0; }
		.research-list li { flex-wrap: wrap; gap: var(--s-3); }
	}
</style>
