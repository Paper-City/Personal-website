---
import Base from '../layouts/Base.astro';
---

<Base title="纸城 — About" current="About" pageNum="01">
	<!-- HERO: dramatic Persona-style opening -->
	<section class="hero">
		<div class="bg-diagonal"></div>

		<div class="tile-collage" aria-hidden="true">
			<div class="tile tile--workshop" data-rotate="4" data-depth="3">
				<img src="/workshop.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--exhibition" data-rotate="-8" data-depth="3">
				<img src="/exhibition.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--presentation" data-rotate="-5" data-depth="2">
				<img src="/presentation.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--prototype" data-rotate="6" data-depth="2">
				<img src="/prototype.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--portrait" data-rotate="-3" data-depth="1">
				<img src="/avatar.png" alt="" />
			</div>
			<div class="tile tile--accent" data-rotate="12" data-depth="1"></div>
		</div>

		<div class="hero__inner">
			<div class="eyebrow hero__eyebrow fade-up fade-up--1">01 ─ ABOUT</div>
			<h1 class="display-xl fade-up fade-up--2">纸城</h1>
			<div class="hero__role fade-up fade-up--3">
				<span>Game</span>
				<span class="hero__role--accent">Systems</span>
				<span>Designer.</span>
			</div>
			<p class="lead fade-up fade-up--4" style="max-width: 540px; margin-top: var(--s-5)">
				Between the precision of science<br />and the intuition of art.
			</p>
			<div class="hero__meta fade-up fade-up--4">
				<span>UAL · MA Game Design</span>
				<span class="hero__meta-dot">/</span>
				<span>Independent Developer</span>
				<span class="hero__meta-dot">/</span>
				<span>2026</span>
			</div>
		</div>

		<div class="scroll-hint">
			<span>Scroll</span>
			<svg width="14" height="20" viewBox="0 0 14 20" fill="none">
				<path d="M7 1V19M7 19L1 13M7 19L13 13" stroke="currentColor" stroke-width="1"/>
			</svg>
		</div>
	</section>

	<!-- BODY: readable content -->
	<section class="body-section">
		<p class="body-lead">
			[一段开场介绍 — 你是谁、在做什么。三五行的篇幅，
			像杂志的开篇引言。这里先用占位文字，等你给我真实文案后我替换。]
		</p>
		<p>
			[第二段可以讲你为什么走这条路 — 来自一种好奇？来自某次具体的体验？
			一个让你着迷的设计案例？这里也是占位。]
		</p>
	</section>

	<div class="pull-quote">
		游戏的设计既需要数学家的精准，也需要诗人的直觉。
		<span class="pull-quote__attr">— 设计哲学</span>
	</div>

	<section class="section">
		<div class="section__head">
			<span class="eyebrow">02 / Education</span>
			<h2>Education</h2>
		</div>
		<div class="two-col">
			<div class="meta-block">
				<div class="meta-block__year">2024 ─ 2026</div>
				<h3>University of the Arts London</h3>
				<p>MA · Game Design</p>
			</div>
			<div class="meta-block">
				<div class="meta-block__year">前期</div>
				<h3>[本科院校]</h3>
				<p>[专业 / 年份]</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section__head">
			<span class="eyebrow">03 / Focus</span>
			<h2>Focus Areas</h2>
		</div>
		<div class="focus-grid">
			<div class="focus-card">
				<div class="focus-card__num">.01</div>
				<div class="eyebrow">As Science</div>
				<h3>System · Math · Pattern</h3>
				<p>
					系统设计、肉鸽机制、数值平衡、玩家行为建模——
					可以被分析、被实验、被复用的部分。
				</p>
			</div>
			<div class="focus-card focus-card--accent">
				<div class="focus-card__num">.02</div>
				<div class="eyebrow eyebrow--invert">As Art</div>
				<h3>Rhythm · Story · Intent</h3>
				<p>
					情感节奏、叙事结构、设计意图的传达——
					不能被量化但能被感受到的部分。
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section__head">
			<span class="eyebrow">04 / Now</span>
			<h2>Now</h2>
		</div>
		<p>
			目前在做：<strong class="hl">Ash of Aetharn</strong> — 一款融合肉鸽与即时战略元素的卡牌游戏。
			同时为 2026 秋招做准备。
		</p>
	</section>
</Base>

<style>
	.hero { min-height: 80vh; }
	.hero__inner {
		max-width: 600px;
		position: relative;
		z-index: 2;
	}
	.hero__role {
		display: flex;
		gap: var(--s-3);
		flex-wrap: wrap;
		margin-top: var(--s-3);
		font-family: var(--font-display);
		font-style: italic;
		font-size: clamp(28px, 4vw, 48px);
		font-weight: 400;
		color: var(--ink-secondary);
	}
	.hero__role--accent { color: var(--accent-bright); font-style: normal; font-weight: 600; }
	.hero__meta {
		margin-top: var(--s-7);
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--ink-muted);
		display: flex;
		gap: var(--s-3);
		flex-wrap: wrap;
	}
	.hero__meta-dot { color: var(--accent); }

	.scroll-hint {
		position: absolute;
		bottom: var(--s-6);
		left: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--s-2);
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		color: var(--ink-muted);
		z-index: 2;
		animation: bobble 2.4s ease-in-out infinite;
	}
	@keyframes bobble {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(8px); }
	}

	.body-section { margin-top: var(--s-10); max-width: var(--content-max); }
	.body-lead {
		font-family: var(--font-display);
		font-size: clamp(20px, 2.4vw, 26px);
		line-height: 1.5;
		font-style: italic;
		color: var(--ink);
		margin-bottom: var(--s-5);
	}

	.meta-block__year {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.2em;
		color: var(--accent-bright);
		margin-bottom: var(--s-3);
	}
	.meta-block h3 { margin-bottom: var(--s-2); }
	.meta-block p { color: var(--ink-muted); font-style: italic; }

	.focus-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--s-4);
	}
	.focus-card {
		position: relative;
		padding: var(--s-7) var(--s-6) var(--s-6);
		background: var(--bg-soft);
		border: 1px solid var(--line);
		transition: all var(--duration) var(--ease);
		overflow: hidden;
	}
	.focus-card:hover {
		border-color: var(--accent);
		transform: translateY(-4px);
	}
	.focus-card__num {
		position: absolute;
		top: var(--s-4);
		right: var(--s-5);
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.2em;
		color: var(--ink-faint);
	}
	.focus-card h3 {
		margin-top: var(--s-3);
		margin-bottom: var(--s-3);
		font-family: var(--font-display);
		font-size: 26px;
		font-weight: 500;
		font-style: italic;
	}
	.focus-card p { color: var(--ink-secondary); }
	.focus-card--accent { background: var(--accent); border-color: var(--accent); }
	.focus-card--accent .focus-card__num { color: rgba(255,255,255,0.5); }
	.focus-card--accent h3 { color: var(--ink); }
	.focus-card--accent p { color: rgba(255,255,255,0.85); }
	.eyebrow--invert { color: var(--ink); opacity: 0.7; }

	.hl { color: var(--accent-bright); font-family: var(--font-display); font-style: italic; font-size: 1.1em; }

	@media (max-width: 900px) {
		.focus-grid { grid-template-columns: 1fr; }
		.scroll-hint { display: none; }
	}
</style>
