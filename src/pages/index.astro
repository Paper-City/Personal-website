---
import Base from '../layouts/Base.astro';
---

<Base title="纸城 — 关于我" current="关于我">
	<!-- HERO -->
	<section class="hero">
		<div class="bg-diagonal"></div>

		<div class="tile-collage" aria-hidden="true">
			<div class="tile tile--workshop" data-rotate="5" data-depth="3">
				<img src="/workshop.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--exhibition" data-rotate="-7" data-depth="3">
				<img src="/exhibition.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--prototype" data-rotate="6" data-depth="2">
				<img src="/prototype.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--presentation" data-rotate="-5" data-depth="2">
				<img src="/presentation.jpg" alt="" loading="lazy" />
			</div>
			<div class="tile tile--portrait" data-rotate="-3" data-depth="1">
				<img src="/avatar.png" alt="" />
			</div>
		</div>

		<div class="hero__inner">
			<div class="eyebrow hero__eyebrow fade-up fade-up--1">01 ─ 关于我</div>

			<div class="hero__head fade-up fade-up--2">
				<div class="hero__name">
					<h1 class="display-xl hero__cn">纸城</h1>
					<div class="hero__divider"></div>
					<div class="hero__author">HUANG TINGYU</div>
				</div>

				<div class="hero__sep" aria-hidden="true"></div>

				<div class="hero__schools">
					<div class="school">
						<span class="school__icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
								<path d="M6 12v5c3 3 9 3 12 0v-5"/>
							</svg>
						</span>
						<div class="school__text">
							<div class="school__name">哈尔滨工业大学</div>
							<div class="school__field">软件工程（数字媒体技术）</div>
						</div>
					</div>
					<div class="school">
						<span class="school__icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/>
							</svg>
						</span>
						<div class="school__text">
							<div class="school__name">伦敦艺术大学</div>
							<div class="school__field">游戏设计</div>
						</div>
					</div>
				</div>
			</div>

			<div class="hero__rule fade-up fade-up--3"></div>

			<p class="hero__lead fade-up fade-up--4">
				我是一名关注<span class="hi">游戏系统</span>、<span class="hi">互动体验</span>与<span class="hi">原型实现</span>的游戏设计师与开发者。
			</p>
		</div>

		<div class="scroll-hint">
			<span>SCROLL</span>
			<svg width="14" height="20" viewBox="0 0 14 20" fill="none">
				<path d="M7 1V19M7 19L1 13M7 19L13 13" stroke="currentColor" stroke-width="1"/>
			</svg>
		</div>
	</section>

	<!-- BODY -->
	<section class="section">
		<div class="section__head">
			<span class="eyebrow">02 / Philosophy</span>
			<h2>我的设计理念</h2>
		</div>
		<p class="philosophy">
			我相信游戏不仅是艺术的表达，更是严谨的工程。
		</p>
		<p class="philosophy">
			比起追求灵光一现，我更喜欢通过理论与测试将设计逐步打磨成有趣的玩法。
		</p>
	</section>

	<section class="section">
		<div class="section__head">
			<span class="eyebrow">03 / Research</span>
			<h2>我在研究的</h2>
		</div>
		<ul class="research-list">
			<li><span class="research-num">.01</span>随机性在提高游戏复玩性中的应用</li>
			<li><span class="research-num">.02</span>提高交互性的隐性系统设计</li>
			<li><span class="research-num">.03</span>AI 与游戏结合</li>
		</ul>
	</section>
</Base>

<style>
	.hero { min-height: 80vh; }
	.hero__inner {
		max-width: 820px;
		position: relative;
		z-index: 2;
	}

	/* Name + schools horizontal row */
	.hero__head {
		display: flex;
		align-items: center;
		gap: var(--s-7);
		flex-wrap: wrap;
		margin-top: var(--s-4);
	}

	/* Name block */
	.hero__name {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	.hero__cn {
		color: var(--ink);
		font-weight: 700;
		font-size: clamp(80px, 14vw, 180px);
		line-height: 0.9;
		letter-spacing: -0.02em;
	}
	.hero__divider {
		width: 48px;
		height: 2px;
		background: var(--accent);
		margin: var(--s-4) 0 var(--s-3);
	}
	.hero__author {
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.42em;
		color: var(--ink);
		text-transform: uppercase;
		padding-left: 2px;
	}

	/* Vertical separator between name and schools */
	.hero__sep {
		width: 1px;
		align-self: stretch;
		background: var(--line);
		min-height: 100px;
	}

	/* Schools block (right of name) */
	.hero__schools {
		display: flex;
		flex-direction: column;
		gap: var(--s-5);
	}
	.school {
		display: flex;
		align-items: flex-start;
		gap: var(--s-4);
	}
	.school__icon {
		flex-shrink: 0;
		width: 40px;
		height: 40px;
		border: 1px solid var(--accent-bright);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--accent-bright);
	}
	.school__icon svg {
		width: 20px;
		height: 20px;
	}
	.school__text { display: flex; flex-direction: column; gap: 4px; }
	.school__name {
		font-family: var(--font-display);
		font-size: 22px;
		font-weight: 600;
		color: var(--accent-bright);
		letter-spacing: 0.01em;
		line-height: 1;
	}
	.school__field {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		color: var(--accent-bright);
		opacity: 0.75;
	}

	/* Horizontal rule between head and lead */
	.hero__rule {
		width: 100%;
		max-width: 760px;
		height: 1px;
		background: var(--line);
		margin: var(--s-7) 0 var(--s-5);
	}

	/* Lead paragraph */
	.hero__lead {
		font-family: var(--font-display);
		font-size: clamp(22px, 2.6vw, 30px);
		line-height: 1.5;
		color: var(--ink);
		max-width: 760px;
		font-style: italic;
	}
	.hero__lead .hi {
		color: var(--accent-bright);
		font-weight: 600;
		font-style: normal;
		font-family: var(--font-display);
		border-bottom: 2px solid var(--accent-bright);
		padding-bottom: 1px;
	}

	.scroll-hint {
		position: absolute;
		bottom: var(--s-6);
		left: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--s-2);
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		color: var(--ink-muted);
		z-index: 2;
		animation: bobble 2.4s ease-in-out infinite;
	}
	@keyframes bobble {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(8px); }
	}

	/* Philosophy */
	.philosophy {
		font-family: var(--font-display);
		font-size: clamp(20px, 2.2vw, 26px);
		line-height: 1.55;
		color: var(--ink);
		max-width: 700px;
	}
	.philosophy + .philosophy {
		margin-top: var(--s-4);
		color: var(--ink-secondary);
		font-style: italic;
	}

	/* Research list */
	.research-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--s-3);
	}
	.research-list li {
		display: flex;
		align-items: baseline;
		gap: var(--s-5);
		padding: var(--s-3) 0;
		border-bottom: 1px solid var(--line);
		font-family: var(--font-display);
		font-size: clamp(20px, 2vw, 24px);
		color: var(--ink);
		transition: color var(--duration) var(--ease);
	}
	.research-list li:hover { color: var(--accent-bright); }
	.research-num {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.2em;
		color: var(--accent-bright);
		min-width: 50px;
	}

	@media (max-width: 900px) {
		.hero__head { flex-direction: column; align-items: flex-start; gap: var(--s-5); }
		.hero__sep { display: none; }
		.research-list li { flex-wrap: wrap; gap: var(--s-3); }
	}
</style>
