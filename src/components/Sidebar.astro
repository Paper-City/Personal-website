---
import { NAV_ITEMS, SOCIAL } from '../consts';

interface Props {
	current?: string;
}
const { current = '' } = Astro.props;
---

<aside class="sidebar">
	<a href="/" class="sidebar__name-block fade-up fade-up--1" aria-label="Home">
		<div class="sidebar__name">纸城</div>
		<span class="sidebar__name-en">Paper City</span>
		<div class="sidebar__tagline">
			Game Systems Designer<br />
			between science & art.
		</div>
	</a>

	<nav class="nav fade-up fade-up--2" aria-label="Primary">
		{NAV_ITEMS.map((item) => (
			<a
				href={item.href}
				class={`nav__item ${item.label === current ? 'nav__item--active' : ''}`}
			>
				<span class="nav__num">{item.num}</span>
				<span>{item.label}</span>
			</a>
		))}
	</nav>

	<div class="sidebar__footer fade-up fade-up--3">
		<div class="sidebar__social">
			<a href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a>
			<a href={SOCIAL.email}>Email</a>
		</div>
		<div>© 2026 — Paper City</div>
	</div>
</aside>
